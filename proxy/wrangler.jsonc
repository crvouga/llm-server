{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "llm-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-03",

  "routes": [
    {
      "pattern": "llm-proxy.chrisvouga.dev",
      "custom_domain": true
    }
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
