    "@neondatabase/serverless": "^1.1.0",
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.1",
    "bun-types": "^1.3.14",
    "prettier": "^3.8.3",
    "typescript": "^5.6.2",
    "wrangler": "^4.98.0"
  }
}
