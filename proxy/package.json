{
  "name": "llm-proxy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gh": "open https://github.com/crvouga/llm-server/actions",
    "start": "bun run src/server.ts",
    "start:vault": "vault run --project personal --config dev -- bun run src/server.ts",
    "dev": "bun run build:ui && bash scripts/dev.sh",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "dev:ui:watch": "vite build --watch",
    "check": "bun run build:ui && tsc --noEmit && tsc -p src/ui/client/tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "bun run build:ui && bun test",
    "test:vault": "vault run --project personal --config dev -- bun test"
  },
  "dependencies": {
    "@heroui/react": "^3.2.0",
    "@heroui/styles": "^3.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.101.0",
    "chart.js": "^4.5.1",
    "highlight.js": "^11.11.1",
    "hono": "^4",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "bun-types": "^1.3.14",
    "prettier": "^3.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.6.2",
    "vite": "^6.3.5"
  }
}