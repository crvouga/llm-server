{
  "name": "llm-proxy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gh": "open https://github.com/crvouga/llm-server/actions",
    "start": "bun run src/server.ts",
    "start:vault": "vault run --project personal --config dev -- bun run src/server.ts",
    "dev": "bash scripts/dev.sh",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "bun test",
    "test:vault": "vault run --project personal --config dev -- bun test"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "hono": "^4"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "prettier": "^3.8.3",
    "typescript": "^5.6.2"
  }
}
